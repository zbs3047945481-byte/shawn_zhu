<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="technical-roadmap" name="技术路线图">
    <mxGraphModel dx="1483" dy="842" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" value="即插即用联邦学习特征蒸馏技术路线图" vertex="1">
          <mxGeometry height="50" width="720" x="430" y="20" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=15;fontStyle=1;" value="1. 问题定义与实验配置&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;main.py / options.py&lt;br&gt;联邦分类任务 + Non-IID 设置&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="210" x="60" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=15;fontStyle=1;" value="2. 数据异构构造&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;MNIST / CIFAR-10&lt;br&gt;Dirichlet 标签偏斜&lt;br&gt;数量偏斜 + 特征偏斜&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="220" x="330" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=15;fontStyle=1;" value="3. FedAvg 联邦主干&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;客户端采样&lt;br&gt;全局模型广播&lt;br&gt;本地训练&lt;br&gt;参数加权聚合&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="220" x="610" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=15;fontStyle=1;" value="4. 插件协议层&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;BaseClientPlugin&lt;br&gt;BaseServerPlugin&lt;br&gt;plugin_name = fedfed_prototype&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="230" x="890" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00838F;fontSize=15;fontStyle=1;" value="5. 客户端特征投影&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;模型输出中间特征 h&lt;br&gt;FeatureSplitModule&lt;br&gt;h → z_s 低维原型空间&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="240" x="170" y="300" as="geometry" />
        </mxCell>
        <mxCell id="s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=15;fontStyle=1;" value="6. 本地类原型提取&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;按类别统计 z_s&lt;br&gt;prototype_c = mean(z_s | y=c)&lt;br&gt;count_c 作为可靠性权重&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="240" x="470" y="300" as="geometry" />
        </mxCell>
        <mxCell id="s7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#AD1457;fontSize=15;fontStyle=1;" value="7. 隐私与稳定性处理&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;L2 归一化&lt;br&gt;原型裁剪 clip_norm&lt;br&gt;高斯噪声 noise_sigma&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="240" x="770" y="300" as="geometry" />
        </mxCell>
        <mxCell id="s8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#558B2F;fontSize=15;fontStyle=1;" value="8. 客户端上传 payload&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;模型参数 weights&lt;br&gt;projection_state&lt;br&gt;class prototypes + counts&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="240" x="1070" y="300" as="geometry" />
        </mxCell>
        <mxCell id="s9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=15;fontStyle=1;" value="9. 服务端联合聚合&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;FedAvg 参数聚合&lt;br&gt;投影层状态加权平均&lt;br&gt;类别原型按 count 加权聚合&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="260" x="330" y="490" as="geometry" />
        </mxCell>
        <mxCell id="s10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#512DA8;fontSize=15;fontStyle=1;" value="10. 全局原型库更新&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;global_prototypes&lt;br&gt;prototype_momentum 平滑&lt;br&gt;广播到下一轮客户端&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="260" x="670" y="490" as="geometry" />
        </mxCell>
        <mxCell id="s11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0277BD;fontSize=15;fontStyle=1;" value="11. 本地联合优化目标&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;L = L_cls + lambda_distill L_distill + lambda_anchor L_anchor&lt;br&gt;余弦原型对齐 + 特征锚定&lt;/font&gt;" vertex="1">
          <mxGeometry height="110" width="300" x="1010" y="490" as="geometry" />
        </mxCell>
        <mxCell id="s12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontSize=15;fontStyle=1;" value="12. 实验评估与论文验证&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;FedAvg vs fedfed_prototype&lt;br&gt;alpha / lambda / dim 敏感性&lt;br&gt;消融实验 + 异构性组合实验&lt;br&gt;metrics.json + 曲线图 + summary.csv&lt;/font&gt;" vertex="1">
