<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="fedfed-beta-vae-generator" name="β-VAE生成器机制图">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=center;" value="FedFed β-VAE 生成器 q(x) 机制原理图" vertex="1">
          <mxGeometry x="390" y="25" width="870" height="50" as="geometry" />
        </mxCell>

        <mxCell id="input" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00695C;fontSize=15;fontStyle=1;" value="输入图像 x&lt;br&gt;CIFAR-10: 3×32×32" vertex="1">
          <mxGeometry x="80" y="220" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="encoder" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#512DA8;fontSize=14;fontStyle=1;" value="Encoder&lt;br&gt;Conv + BN + ReLU&lt;br&gt;下采样提取潜在表示" vertex="1">
          <mxGeometry x="390" y="205" width="250" height="115" as="geometry" />
        </mxCell>
        <mxCell id="mu" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=14;" value="μ(x)&lt;br&gt;潜变量均值" vertex="1">
          <mxGeometry x="740" y="150" width="180" height="75" as="geometry" />
        </mxCell>
        <mxCell id="logvar" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=14;" value="logσ²(x)&lt;br&gt;潜变量方差" vertex="1">
          <mxGeometry x="740" y="295" width="180" height="75" as="geometry" />
        </mxCell>
        <mxCell id="sample" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=14;fontStyle=1;" value="重参数采样&lt;br&gt;z = μ + σ · ε&lt;br&gt;ε ~ N(0, I)" vertex="1">
          <mxGeometry x="1010" y="220" width="240" height="105" as="geometry" />
        </mxCell>
        <mxCell id="decoder" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=14;fontStyle=1;" value="Decoder&lt;br&gt;Deconv + BN + ReLU&lt;br&gt;Sigmoid 输出图像空间结果" vertex="1">
          <mxGeometry x="1340" y="205" width="250" height="115" as="geometry" />
        </mxCell>

        <mxCell id="xr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=15;fontStyle=1;" value="生成器输出&lt;br&gt;x_r = q(x)&lt;br&gt;性能鲁棒/重构部分" vertex="1">
          <mxGeometry x="1110" y="470" width="260" height="105" as="geometry" />
        </mxCell>
        <mxCell id="subtract" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=18;fontStyle=1;" value="x - x_r" vertex="1">
          <mxGeometry x="790" y="480" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="xs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;fontSize=15;fontStyle=1;" value="性能敏感特征&lt;br&gt;x_s = x - q(x)&lt;br&gt;上传到共享池" vertex="1">
          <mxGeometry x="450" y="465" width="260" height="110" as="geometry" />
        </mxCell>

        <mxCell id="recon" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0277BD;fontSize=14;fontStyle=1;" value="重构稳定项&lt;br&gt;L_recon = MSE(q(x), x)&lt;br&gt;让 q(x) 不乱生成，接近原图结构" vertex="1">
          <mxGeometry x="220" y="700" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="kl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=14;fontStyle=1;" value="潜空间正则&lt;br&gt;L_kl = KL(N(μ, σ²) || N(0, I))&lt;br&gt;让 z 空间平滑、稳定、可泛化" vertex="1">
          <mxGeometry x="660" y="700" width="390" height="110" as="geometry" />
        </mxCell>
        <mxCell id="fd" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=14;fontStyle=1;" value="分类可用性约束&lt;br&gt;L_fd = CE(f(x_s), y)&lt;br&gt;保证 x_s 保留类别判别信息" vertex="1">
          <mxGeometry x="1160" y="700" width="340" height="110" as="geometry" />
        </mxCell>

        <mxCell id="summary" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6F8FA;strokeColor=#607D8B;fontSize=15;fontStyle=1;align=left;spacingLeft=16;" value="直观理解：&lt;br&gt;1. Encoder 把图像压到潜空间分布 N(μ, σ²)。&lt;br&gt;2. 通过重参数采样得到 z，让训练可反向传播。&lt;br&gt;3. Decoder 从 z 重构出 x_r = q(x)。&lt;br&gt;4. 用 x_s = x - x_r 得到要共享的性能敏感特征。&lt;br&gt;5. L_recon 和 L_kl 稳定生成器，L_fd 保证 x_s 对分类有用。" vertex="1">
          <mxGeometry x="270" y="860" width="1110" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="input" target="encoder" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#00695C;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" edge="1" parent="1" source="encoder" target="mu" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#7B1FA2;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" edge="1" parent="1" source="encoder" target="logvar" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#7B1FA2;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" edge="1" parent="1" source="mu" target="sample" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#F9A825;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" edge="1" parent="1" source="logvar" target="sample" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#F9A825;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" edge="1" parent="1" source="sample" target="decoder" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#1565C0;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" edge="1" parent="1" source="decoder" target="xr" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#2E7D32;"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1465" y="400" /><mxPoint x="1240" y="400" /></Array></mxGeometry></mxCell>
        <mxCell id="e8" edge="1" parent="1" source="input" target="subtract" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#C62828;"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="185" y="520" /></Array></mxGeometry></mxCell>
        <mxCell id="e9" edge="1" parent="1" source="xr" target="subtract" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#C62828;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" edge="1" parent="1" source="subtract" target="xs" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#C2185B;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" edge="1" parent="1" source="xr" target="recon" style="endArrow=block;html=1;dashed=1;strokeWidth=2;strokeColor=#0277BD;" value="和 x 比较"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1240" y="650" /><mxPoint x="390" y="650" /></Array></mxGeometry></mxCell>
        <mxCell id="e12" edge="1" parent="1" source="mu" target="kl" style="endArrow=block;html=1;dashed=1;strokeWidth=2;strokeColor=#EF6C00;"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="830" y="650" /></Array></mxGeometry></mxCell>
        <mxCell id="e13" edge="1" parent="1" source="logvar" target="kl" style="endArrow=block;html=1;dashed=1;strokeWidth=2;strokeColor=#EF6C00;"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="830" y="650" /></Array></mxGeometry></mxCell>
        <mxCell id="e14" edge="1" parent="1" source="xs" target="fd" style="endArrow=block;html=1;dashed=1;strokeWidth=2;strokeColor=#C62828;"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="580" y="650" /><mxPoint x="1330" y="650" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
