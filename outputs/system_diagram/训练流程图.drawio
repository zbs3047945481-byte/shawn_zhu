        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="broadcast" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#0277BD;" target="local">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="local" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#0277BD;" target="upload">
          <mxGeometry relative="1" as="geometry" />
