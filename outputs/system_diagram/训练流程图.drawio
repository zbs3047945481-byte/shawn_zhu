        <mxCell id="e3" edge="1" parent="1" source="init" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#555555;" target="eval0">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="eval0" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#0277BD;fontSize=12;" target="select" value="未早停">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="select" style="endArrow=block;html=1;strokeWidth=2;strokeColor=#0277BD;" target="broadcast">
